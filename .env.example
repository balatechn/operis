# Environment variables for Docker / Coolify
# Set these in Coolify dashboard - DO NOT commit this file with real values

# PostgreSQL (managed by Coolify)
POSTGRES_HOST=your-coolify-postgres-host
POSTGRES_PORT=5432
POSTGRES_USER=operis
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=operis

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=change-this-very-long-random-secret-key

# CORS
CORS_ORIGIN=https://your-web-domain.com

# Frontend
NEXT_PUBLIC_API_URL=https://your-api-domain.com/api/v1
NEXT_PUBLIC_WS_URL=https://your-api-domain.com

# Example environment variables for Operis Backend (NestJS)
# Copy this file to .env and fill in actual values for deployment

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=operis

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# WebSocket
WS_PORT=3001

# App
PORT=3000
NODE_ENV=development

# Coolify-specific variables (set these in Coolify dashboard, not in code)
# DATABASE_URL=postgresql://postgres:yourpassword@host:5432/operis
# REDIS_URL=redis://:password@host:6379
